rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared song library — any authenticated user can read/write
    match /songs/{songId} {
      allow read, write: if request.auth != null;
    }

    // Shared setlists — any authenticated user can read/write
    match /setlists/{setlistId} {
      allow read, write: if request.auth != null;
    }

    // Legacy per-user collections (kept for backward compatibility during migration)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
