rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared song library — any authenticated user can read/write
    match /songs/{songId} {
      allow read, write: if request.auth != null;
    }

    // Shared setlists — any authenticated user can read/write
    match /setlists/{setlistId} {
      allow read, write: if request.auth != null;
    }

    // Admin config — any authenticated user can read;
    // allow create if doc doesn't exist yet (first-admin seed), otherwise only admins can write
    match /config/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/config/admins)
        && request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // Legacy per-user collections (kept for backward compatibility during migration)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
